{
  "name": "nhatroso-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Nhatroso Platform",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@nhatroso/api-server",
    "dev:web": "turbo run dev --filter=@nhatroso/admin-web",
    "dev:app": "turbo run dev --filter=@nhatroso/tenant-app",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@nhatroso/api-server",
    "build:web": "turbo run build --filter=@nhatroso/admin-web",
    "build:app": "turbo run build --filter=@nhatroso/tenant-app",
    "test": "turbo run test",
    "test:api": "turbo run test --filter=@nhatroso/api-server",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "clean:all": "rm -rf node_modules .turbo",
    "prepare": "husky",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:stop": "docker compose -f infra/docker/docker-compose.yml stop",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.11",
    "typescript": "^5.4.5"
  }
}
