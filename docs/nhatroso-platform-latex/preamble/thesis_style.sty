% Design cover page
\def\coverpage{
    % --- TikZ Border ---
    \begin{tikzpicture}[remember picture, overlay]
        % Outer border
        \draw[line width=1.5pt, chaptercolor]
            ($(current page.north west) + (3.0cm,-2.0cm)$)
            rectangle
            ($(current page.south east) + (-1.5cm,1.5cm)$);
        % Inner border
        \draw[line width=0.5pt, chaptercolor]
            ($(current page.north west) + (3.15cm,-2.15cm)$)
            rectangle
            ($(current page.south east) + (-1.65cm,1.65cm)$);


        % Simpler ornaments for reliability
        \draw[line width=1pt, chaptercolor] ($(current page.north west) + (3.15cm,-3.15cm)$) -- ($(current page.north west) + (3.15cm,-2.15cm)$) -- ($(current page.north west) + (4.15cm,-2.15cm)$);
        \draw[line width=1pt, chaptercolor] ($(current page.north east) + (-1.65cm,-3.15cm)$) -- ($(current page.north east) + (-1.65cm,-2.15cm)$) -- ($(current page.north east) + (-2.65cm,-2.15cm)$);
        \draw[line width=1pt, chaptercolor] ($(current page.south east) + (-1.65cm,3.15cm)$) -- ($(current page.south east) + (-1.65cm,1.65cm)$) -- ($(current page.south east) + (-2.65cm,1.65cm)$);
        \draw[line width=1pt, chaptercolor] ($(current page.south west) + (3.15cm,3.15cm)$) -- ($(current page.south west) + (3.15cm,1.65cm)$) -- ($(current page.south west) + (4.15cm,1.65cm)$);
    \end{tikzpicture}

    % --- Content ---
    \begin{center}
        {\fontsize{13}{15}\selectfont \textbf{BỘ GIÁO DỤC VÀ ĐÀO TẠO}}\\[0.2cm]
        {\fontsize{14}{17}\selectfont \textbf{TRƯỜNG ĐẠI HỌC NHA TRANG}}\\[0.2cm]
        {\fontsize{13}{15}\selectfont \textbf{\@sdeptname}}\\[0.5cm]
        \textbf{--------------------------*} \textbf{*--------------------------}

        \vfill
        \includegraphics[width=4.0cm]{assets/figures/ntu_logo.jpg}
        \vfill

        {\fontsize{16}{20}\selectfont \textbf{\@rname}}\\[1.2cm]

        \begin{minipage}{0.9\textwidth}
            \centering
            {\fontsize{22}{28}\selectfont \textbf{\color{chaptercolor} \@tname}}
        \end{minipage}

        \vfill

        \begin{flushleft}
            \hspace{2.5cm}
            \begin{tabular}{lll}
                {\fontsize{13}{16}\selectfont \textbf{Giảng viên hướng dẫn}} & {\fontsize{13}{16}\selectfont \textbf{:}} & {\fontsize{13}{16}\selectfont \@sSupervise} \\[0.3cm]
                {\fontsize{13}{16}\selectfont \textbf{Sinh viên thực hiện}} & {\fontsize{13}{16}\selectfont \textbf{:}} & {\fontsize{13}{16}\selectfont \@stuname} \\[0.3cm]
                {\fontsize{13}{16}\selectfont \textbf{MSSV}} & {\fontsize{13}{16}\selectfont \textbf{:}} & {\fontsize{13}{16}\selectfont \@sCouncil}
            \end{tabular}
        \end{flushleft}

        \vfill
        {\fontsize{13}{15}\selectfont \textbf{\@ttime}}
        \vspace{0.8cm}
    \end{center}
    \clearpage
}

\def\makeprintversion{}

\RequirePackage{titlesec}
\titleformat{\chapter}[display]
  {\normalfont\huge\bfseries\color{chaptercolor}}
  {\chaptertitlename\ \thechapter}{20pt}{\Huge}
\titlespacing*{\chapter}{0pt}{-20pt}{40pt}

%% Remember to load babel before loading this package or define the command \abstractname!
\makeatletter
\newenvironment{abstract}{
  \chapter*{\abstractname}
  \addcontentsline{toc}{chapter}{\abstractname}
}{}
\makeatother

\makeatletter
\newenvironment{acknowledgments}{
  \chapter*{Lời cảm ơn}
  \addcontentsline{toc}{chapter}{Lời cảm ơn}
  \quotation
}{}
\makeatother

% Declaration
\makeatletter
\newenvironment{declaration}{
  \chapter*{Lời cam đoan}
  \addcontentsline{toc}{chapter}{Lời cam đoan}
  \quotation
}{}
\makeatother

