% Design cover page
\def\coverpage{
    % --- TikZ Border ---
    \begin{tikzpicture}[remember picture, overlay]
        % Base coordinates
        \coordinate (NW) at ($(current page.north west) + (3.0cm,-2.0cm)$);
        \coordinate (SE) at ($(current page.south east) + (-1.5cm,1.5cm)$);
        \coordinate (NWinner) at ($(current page.north west) + (3.2cm,-2.2cm)$);
        \coordinate (SEinner) at ($(current page.south east) + (-1.7cm,1.7cm)$);

        % Main double border
        \draw[line width=1.2pt, chaptercolor] (NW) rectangle (SE);
        \draw[line width=2.8pt, chaptercolor] (NWinner) rectangle (SEinner);

        % Corner Ornaments (Manual for parser safety)
        \begin{scope}[shift={($(current page.north west) + (3.2cm,-2.2cm)$)}, rotate=0]
            \draw[line width=1pt, chaptercolor] (0, -0.8) -- (0,0) -- (0.8, 0);
        \end{scope}
        \begin{scope}[shift={($(current page.north east) + (-1.7cm,-2.2cm)$)}, rotate=-90]
            \draw[line width=1pt, chaptercolor] (0, -0.8) -- (0,0) -- (0.8, 0);
        \end{scope}
        \begin{scope}[shift={($(current page.south east) + (-1.7cm,1.7cm)$)}, rotate=-180]
            \draw[line width=1pt, chaptercolor] (0, -0.8) -- (0,0) -- (0.8, 0);
        \end{scope}
        \begin{scope}[shift={($(current page.south west) + (3.2cm,1.7cm)$)}, rotate=90]
            \draw[line width=1pt, chaptercolor] (0, -0.8) -- (0,0) -- (0.8, 0);
        \end{scope}
    \end{tikzpicture}

    % --- Content ---
    \begin{center}
        {\fontsize{14}{16}\selectfont \textbf{BỘ GIÁO DỤC VÀ ĐÀO TẠO}}\\[0.4cm]
        {\fontsize{16}{19}\selectfont \textbf{TRƯỜNG ĐẠI HỌC NHA TRANG}}\\[0.4cm]
        {\fontsize{14}{16}\selectfont \textbf{\@sdeptname}}\\
        \textbf{-----------------------------------------}

        \vfill
        \includegraphics[width=4.5cm]{assets/figures/ntu_logo.jpg}
        \vfill

        {\fontsize{18}{22}\selectfont \textbf{\@rname}}

        \vspace{1.5cm}

        \begin{minipage}{0.85\textwidth}
            \centering
            {\fontsize{22}{28}\selectfont \textbf{\color{chaptercolor} \@tname}}
        \end{minipage}

        \vfill

        \begin{flushleft}
            \hspace{1.5cm}
            \begin{minipage}{0.8\textwidth}
                {\fontsize{14}{18}\selectfont
                {\bfseries Sinh viên thực hiện:} \@stuname\\
                {\bfseries Lớp:} \@sCouncil\\
                {\bfseries Giảng viên hướng dẫn:} \@sSupervise
                }
            \end{minipage}
        \end{flushleft}

        \vfill
        {\fontsize{14}{16}\selectfont \textbf{\@ttime}}
        \vspace{1cm}
    \end{center}
    \clearpage
}

