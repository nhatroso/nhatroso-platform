# -----------------------------------------------------------------------------
# DATABASE & REDIS
# -----------------------------------------------------------------------------
DATABASE_URL=
DATABASE_ENABLE_LOGGING=false
DATABASE_AUTO_MIGRATE=true
DATABASE_DANGEROUSLY_TRUNCATE=false
DATABASE_DANGEROUSLY_RECREATE=false

DB_CONNECT_TIMEOUT=500
DB_IDLE_TIMEOUT=500
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=1

REDIS_URL=
REDIS_DANGEROUSLY_FLUSH=false

# -----------------------------------------------------------------------------
# SERVER & APP CONFIGURATION
# -----------------------------------------------------------------------------
PORT=5150
SERVER_BINDING=0.0.0.0
SERVER_HOST=http://localhost
WORKER_MODE=BackgroundQueue

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRATION=604800

# -----------------------------------------------------------------------------
# AWS CONFIGURATION (Global, S3, SES)
# -----------------------------------------------------------------------------
AWS_REGION=

# AWS S3
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# AWS SES (Email)
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
EMAIL_FROM=
EMAIL_TIMEOUT=10
EMAIL_RATE_LIMIT=50

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES & PATHS
# -----------------------------------------------------------------------------
GOOGLE_VISION_API_KEY=
TEMPLATE_DIR=src/templates

# -----------------------------------------------------------------------------
# TELEMETRY & LOGGING
# -----------------------------------------------------------------------------
LOGGER_ENABLE=true
LOGGER_PRETTY_BACKTRACE=true
LOGGER_LEVEL=debug
LOGGER_FORMAT=compact
